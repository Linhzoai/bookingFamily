generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id                  String              @id @default(uuid())
  role                String              @db.VarChar(50)
  name                String              @db.VarChar(255)
  email               String              @unique @db.VarChar(255)
  phone               String              @db.VarChar(20)
  hashPassword        String              @map("hash_password") @db.VarChar(255)
  address             String?             @db.VarChar(500)
  gender              String?             @db.VarChar(10)
  areaId              Int?                @map("area_id")
  status              String              @default("active")
  avatarUrl           String?             @map("avatar_url") @db.VarChar(500)
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @default(now()) @updatedAt @map("updated_at")
  auditLogs           AuditLog[]
  bookings            Booking[]           @relation("CustomerBookings")
  contracts           Contract[]
  issueReports        IssueReport[]
  approvedLeaves      LeaveRequest[]      @relation("ApprovedLeaves")
  leaveRequests       LeaveRequest[]      @relation("StaffLeaveRequests")
  notifications       Notification[]
  reviewsAsCustomer   Review[]            @relation("CustomerReviews")
  reviewsAsStaff      Review[]            @relation("StaffReviews")
  rewardsApprovedBy   RewardsDiscipline[] @relation("RewardsApprovedBy")
  rewardsAsStaff      RewardsDiscipline[] @relation("StaffRewards")
  sessions            Session[]
  staffAssignments    StaffAssignment[]   @relation("StaffAssignments")
  staffProfile        StaffProfile?
  staffSchedules      StaffSchedule[]
  staffServiceAreas   StaffServiceArea[]
  staffTraining       StaffTraining[]
  taskProgressUpdates TaskProgress[]
  area                ServiceArea?        @relation(fields: [areaId], references: [id])

  @@index([areaId], map: "users_area_id_fkey")
  @@map("users")
}

model Service {
  id          Int       @id @default(autoincrement()) @map("service_id")
  name        String    @db.VarChar(255)
  description String    @db.Text
  price       Decimal   @db.Decimal(12, 2)
  duration    Int
  imageUrl    String?   @map("image_url") @db.VarChar(500)
  active      Boolean   @default(true)
  categoryId  Int       @map("category_id")
  category    ServiceCategory @relation(fields: [categoryId], references: [id])
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")
  bookingDetails BookingDetails[]

  @@map("services")
}

model Booking {
  id               String            @id @default(uuid()) @map("booking_id")
  customerId       String            @map("customer_id")
  address          String            @db.VarChar(500)
  areaId           Int               @map("area_id")
  scheduledTime    DateTime          @map("scheduled_time")
  discountCodeId   String?           @map("discount_code_id")
  status           String            @db.VarChar(50)
  note             String?           @db.Text
  totalAmount      Decimal           @map("total_amount") @db.Decimal(12, 2)
  actualStartTime  DateTime?         @map("actual_start_time")
  cancelReason     String?           @map("cancel_reason") @db.Text
  actualEndTime    DateTime?         @map("actual_end_time")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @default(now()) @updatedAt @map("updated_at")
  area             ServiceArea       @relation(fields: [areaId], references: [id])
  customer         User              @relation("CustomerBookings", fields: [customerId], references: [id])
  discountCode     DiscountCode?     @relation(fields: [discountCodeId], references: [id])
  issueReports     IssueReport[]
  payments         Payment[]
  review           Review?
  staffAssignments StaffAssignment[]
  taskProgress     TaskProgress[]
  bookingDetails   BookingDetails[]

  @@index([areaId], map: "bookings_area_id_fkey")
  @@index([customerId], map: "bookings_customer_id_fkey")
  @@index([discountCodeId], map: "bookings_discount_code_id_fkey")
  @@map("bookings")
}

model StaffAssignment {
  id         Int      @id @default(autoincrement()) @map("assign_id")
  bookingId  String   @map("booking_id")
  staffId    String   @map("staff_id")
  assignedAt DateTime @map("assigned_at")
  status     String   @db.VarChar(50)
  booking    Booking  @relation(fields: [bookingId], references: [id])
  staff      User     @relation("StaffAssignments", fields: [staffId], references: [id])

  @@index([bookingId], map: "staff_assignments_booking_id_fkey")
  @@index([staffId], map: "staff_assignments_staff_id_fkey")
  @@map("staff_assignments")
}

model Payment {
  id            Int       @id @default(autoincrement()) @map("payment_id")
  bookingId     String    @map("booking_id")
  amount        Decimal   @db.Decimal(12, 2)
  method        String    @db.VarChar(50)
  status        String    @db.VarChar(50)
  transactionId String?   @map("transaction_id") @db.VarChar(255)
  paidAt        DateTime? @map("paid_at")
  booking       Booking   @relation(fields: [bookingId], references: [id])

  @@index([bookingId], map: "payments_booking_id_fkey")
  @@map("payments")
}

model Notification {
  id        Int      @id @default(autoincrement()) @map("notification_id")
  userId    String   @map("user_id")
  message   String   @db.Text
  type      String   @db.VarChar(50)
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId], map: "notifications_user_id_fkey")
  @@map("notifications")
}

model AuditLog {
  id        Int      @id @default(autoincrement()) @map("log_id")
  userId    String?  @map("user_id")
  entity    String   @db.VarChar(100)
  entityId  Int      @map("entity_id")
  action    String   @db.VarChar(50)
  timestamp DateTime @default(now())
  details   String?  @db.Text
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId], map: "audit_logs_user_id_fkey")
  @@map("audit_logs")
}

model StaffProfile {
  id                  Int      @id @default(autoincrement()) @map("profile_id")
  staffId             String   @unique @map("staff_id")
  idCardNumber        String   @unique @map("id_card_number") @db.VarChar(50)
  skills              String   @db.Text
  hireDate            DateTime @map("hire_date") @db.Date
  status              String   @db.VarChar(50)
  currentAvailability String   @default("available") @map("current_availability") @db.VarChar(50)
  staff               User     @relation(fields: [staffId], references: [id])

  @@map("staff_profiles")
}

model Contract {
  id             Int       @id @default(autoincrement()) @map("contract_id")
  contractNumber String    @unique @map("contract_number") @db.VarChar(100)
  staffId        String    @map("staff_id")
  contractType   String    @map("contract_type") @db.VarChar(50)
  signDate       DateTime  @map("sign_date") @db.Date
  startDate      DateTime  @map("start_date") @db.Date
  endDate        DateTime? @map("end_date") @db.Date
  baseSalary     Decimal   @map("base_salary") @db.Decimal(12, 2)
  commissionRate Decimal?  @map("commission_rate") @db.Decimal(5, 2)
  status         String    @db.VarChar(50)
  fileUrl        String?   @map("file_url") @db.VarChar(500)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at")
  staff          User      @relation(fields: [staffId], references: [id])

  @@index([staffId], map: "contracts_staff_id_fkey")
  @@map("contracts")
}

model LeaveRequest {
  id         Int      @id @default(autoincrement()) @map("leave_id")
  staffId    String   @map("staff_id")
  startTime  DateTime @map("start_time")
  endTime    DateTime @map("end_time")
  reason     String   @db.Text
  status     String   @db.VarChar(50)
  approvedBy String?  @map("approved_by")
  createdAt  DateTime @default(now()) @map("created_at")
  approver   User?    @relation("ApprovedLeaves", fields: [approvedBy], references: [id])
  staff      User     @relation("StaffLeaveRequests", fields: [staffId], references: [id])

  @@index([approvedBy], map: "leave_requests_approved_by_fkey")
  @@index([staffId], map: "leave_requests_staff_id_fkey")
  @@map("leave_requests")
}

model Review {
  id         Int      @id @default(autoincrement()) @map("review_id")
  bookingId  String   @unique @map("booking_id")
  customerId String   @map("customer_id")
  staffId    String   @map("staff_id")
  type       String   @db.VarChar(50)
  rating     Int
  comment    String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")
  booking    Booking  @relation(fields: [bookingId], references: [id])
  customer   User     @relation("CustomerReviews", fields: [customerId], references: [id])
  staff      User     @relation("StaffReviews", fields: [staffId], references: [id])

  @@index([customerId], map: "reviews_customer_id_fkey")
  @@index([staffId], map: "reviews_staff_id_fkey")
  @@map("reviews")
}

model IssueReport {
  id          Int      @id @default(autoincrement()) @map("report_id")
  bookingId   String?  @map("booking_id")
  reportedBy  String   @map("reported_by")
  issueType   String   @map("issue_type") @db.VarChar(100)
  description String   @db.Text
  status      String   @db.VarChar(50)
  resolution  String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  booking     Booking? @relation(fields: [bookingId], references: [id])
  reporter    User     @relation(fields: [reportedBy], references: [id])

  @@index([bookingId], map: "issue_reports_booking_id_fkey")
  @@index([reportedBy], map: "issue_reports_reported_by_fkey")
  @@map("issue_reports")
}

model TaskProgress {
  id               Int      @id @default(autoincrement()) @map("progress_id")
  bookingId        String   @map("booking_id")
  staffId          String   @map("staff_id")
  stepName         String   @map("step_name") @db.VarChar(100)
  evidenceImageUrl String?  @map("evidence_image_url") @db.VarChar(500)
  note             String?  @db.Text
  recordedAt       DateTime @map("recorded_at")
  booking          Booking  @relation(fields: [bookingId], references: [id])
  staff            User     @relation(fields: [staffId], references: [id])

  @@index([bookingId], map: "task_progress_booking_id_fkey")
  @@index([staffId], map: "task_progress_staff_id_fkey")
  @@map("task_progress")
}

model ServiceArea {
  id                Int                @id @default(autoincrement()) @map("area_id")
  name              String             @db.VarChar(255)
  parentId          Int?               @map("parent_id")
  isActive          Boolean            @default(true) @map("is_active")
  createdAt         DateTime           @default(now()) @map("created_at")
  bookings          Booking[]
  parent            ServiceArea?       @relation("AreaHierarchy", fields: [parentId], references: [id])
  children          ServiceArea[]      @relation("AreaHierarchy")
  staffServiceAreas StaffServiceArea[]
  users             User[]

  @@index([parentId], map: "service_areas_parent_id_fkey")
  @@map("service_areas")
}

model StaffServiceArea {
  staffId     String      @map("staff_id")
  areaId      Int         @map("area_id")
  primaryArea Boolean     @default(false) @map("primary_area")
  area        ServiceArea @relation(fields: [areaId], references: [id])
  staff       User        @relation(fields: [staffId], references: [id])

  @@id([staffId, areaId])
  @@index([areaId], map: "staff_service_areas_area_id_fkey")
  @@map("staff_service_areas")
}

model DiscountCode {
  id                String    @id @default(uuid()) @map("code_id")
  code              String    @unique @db.VarChar(100)
  description       String    @db.Text
  discountType      String    @map("discount_type") @db.VarChar(50)
  discountValue     Decimal   @map("discount_value") @db.Decimal(12, 2)
  minBookingAmount  Decimal   @map("min_booking_amount") @db.Decimal(12, 2)
  maxDiscountAmount Decimal?  @map("max_discount_amount") @db.Decimal(12, 2)
  startDate         DateTime  @map("start_date")
  endDate           DateTime  @map("end_date")
  usageLimit        Int       @map("usage_limit")
  usedCount         Int       @default(0) @map("used_count")
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at")
  bookings          Booking[]

  @@map("discount_codes")
}

model TrainingCourse {
  id            Int             @id @default(autoincrement()) @map("course_id")
  courseName    String          @map("course_name") @db.VarChar(255)
  description   String          @db.Text
  trainerName   String          @map("trainer_name") @db.VarChar(255)
  durationHours Int             @map("duration_hours")
  status        String          @db.VarChar(50)
  createdAt     DateTime        @default(now()) @map("created_at")
  staffTraining StaffTraining[]

  @@map("training_courses")
}

model StaffTraining {
  id             Int            @id @default(autoincrement()) @map("training_record_id")
  staffId        String         @map("staff_id")
  courseId       Int            @map("course_id")
  enrollmentDate DateTime       @map("enrollment_date") @db.Date
  completionDate DateTime?      @map("completion_date") @db.Date
  resultScore    Decimal?       @map("result_score") @db.Decimal(5, 2)
  status         String         @db.VarChar(50)
  certificateUrl String?        @map("certificate_url") @db.VarChar(500)
  notes          String?        @db.Text
  course         TrainingCourse @relation(fields: [courseId], references: [id])
  staff          User           @relation(fields: [staffId], references: [id])

  @@index([courseId], map: "staff_training_course_id_fkey")
  @@index([staffId], map: "staff_training_staff_id_fkey")
  @@map("staff_training")
}

model RewardsDiscipline {
  id            Int      @id @default(autoincrement()) @map("rd_id")
  staffId       String   @map("staff_id")
  category      String   @db.VarChar(50)
  typeName      String   @map("type_name") @db.VarChar(255)
  reason        String   @db.Text
  amount        Decimal  @default(0.00) @db.Decimal(12, 2)
  decisionDate  DateTime @map("decision_date") @db.Date
  effectiveDate DateTime @map("effective_date") @db.Date
  approvedBy    String?  @map("approved_by")
  fileUrl       String?  @map("file_url") @db.VarChar(500)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")
  approver      User?    @relation("RewardsApprovedBy", fields: [approvedBy], references: [id])
  staff         User     @relation("StaffRewards", fields: [staffId], references: [id])

  @@index([approvedBy], map: "rewards_discipline_approved_by_fkey")
  @@index([staffId], map: "rewards_discipline_staff_id_fkey")
  @@map("rewards_discipline")
}

model WorkShift {
  id             Int             @id @default(autoincrement()) @map("shift_id")
  shiftName      String          @map("shift_name") @db.VarChar(100)
  startTime      DateTime        @map("start_time") @db.Time(0)
  endTime        DateTime        @map("end_time") @db.Time(0)
  isActive       Boolean         @default(true) @map("is_active")
  staffSchedules StaffSchedule[]

  @@map("work_shifts")
}

model StaffSchedule {
  id        Int       @id @default(autoincrement()) @map("schedule_id")
  staffId   String    @map("staff_id")
  shiftId   Int       @map("shift_id")
  dayOfWeek Int       @map("day_of_week")
  workDate  DateTime? @map("work_date") @db.Date
  status    String    @db.VarChar(50)
  createdAt DateTime  @default(now()) @map("created_at")
  shift     WorkShift @relation(fields: [shiftId], references: [id])
  staff     User      @relation(fields: [staffId], references: [id])

  @@index([shiftId], map: "staff_schedules_shift_id_fkey")
  @@index([staffId], map: "staff_schedules_staff_id_fkey")
  @@map("staff_schedules")
}

model Session {
  id           Int      @id @default(autoincrement()) @map("session_id")
  userId       String   @map("user_id")
  token        String   @unique @map("token") 
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id])

  @@index([userId], map: "sessions_user_id_fkey")
  @@map("sessions")
}

model ServiceCategory{
  id            Int             @id @default(autoincrement()) @map("category_id")
  name          String          @unique @map("name") @db.VarChar(255)
  description   String          @db.Text
  iconUrl       String?         @map("icon_url") @db.VarChar(500)
  isActive      Boolean         @default(true) @map("is_active")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @default(now()) @updatedAt @map("updated_at")
  services      Service[]

  @@map("service_categories")
}

model BookingDetails{
  id        Int       @id @default(autoincrement()) @map("booking_detail_id")
  bookingId String    @map("booking_id") 
  serviceId Int       @map("service_id")
  quantity  Int       @default(1) @map("quantity")
  unitPrice Decimal   @map("unit_price") @db.Decimal(12, 2)
  notes     String    @db.Text
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at")

  booking   Booking   @relation(fields: [bookingId], references: [id])
  service   Service   @relation(fields: [serviceId], references: [id])

  @@map("booking_details")
}