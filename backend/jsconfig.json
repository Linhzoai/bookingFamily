{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "#/*": ["./src/*"],
      "#config/*": ["./src/config/*"],
      "#middleware/*": ["./src/middlewares/*"],
      "#utils/*": ["./src/utils/*"],
      "#constants/*": ["./src/constants/*"],
      "#modules/*": ["./src/modules/*"],
      "#routes/*": ["./src/routes/*"],
      "#helper/*": ["./src/helper/*"]
    }
  },
  "include": ["src/**/*"]
}
